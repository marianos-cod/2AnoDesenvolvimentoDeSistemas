Algoritmo "correçãoex1 05/02/26"

Var
base , altura , area :real

Inicio
//Trecho para coletar as medidas
escreval ("Escreva a medida da base")
leia(base)
escreval("Escreva a medida da altura")
leia(altura)

//Trecho para calcular area
area <- base * altura

//Trecho para mostrar resultado
escreval ("O resultado da area é :", area)


Fimalgoritmo